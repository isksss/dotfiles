[init]
	defaultBranch = main

[ghq]
  root = ~/ghq

# Default: personal user
[user]
	name = isksss
	email = 104404522+isksss@users.noreply.github.com

[i18n]
        commitEncoding = utf-8
        logOutputEncoding = utf-8

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = zdiff3

[include]
	path = ~/.config/git/local.gitconfig

# Work user
[includeIf "gitdir:~/ghq/"]
	path = ~/.config/git/work.gitconfig
