#!/bin/sh

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

printf '%s\n' '==> shell syntax and formatting'
sh -n bootstrap.sh dotfiles/.local/bin/update .mise/tasks/check
bash -n dotfiles/.bashrc
find dotfiles/.config/zsh -type f \( -name '*.zsh' -o -name '.zshrc' -o -name '.zprofile' \) -exec zsh -n {} +
zsh -n dotfiles/.zshenv
shfmt -d bootstrap.sh dotfiles/.local/bin/update .mise/tasks/check

printf '%s\n' '==> Neovim configuration'
find dotfiles/.config/nvim -type f -name '*.lua' | while IFS= read -r lua_file; do
	nvim --headless -u NONE "+lua assert(loadfile([[$lua_file]]))" +qa >/dev/null
done
nvim --headless -u "$repo_root/dotfiles/.config/nvim/init.lua" +qa >/dev/null

printf '%s\n' '==> JSON configuration'
jq empty .mcp.json

printf '%s\n' '==> mise and dotfiles configuration'
mise tasks validate
mise dotfiles status --missing >/dev/null

printf '%s\n' '==> self-authored skills'
validator=".agents/skills/.system/skill-creator/scripts/quick_validate.py"
if [ ! -f "$validator" ]; then
	validator="${CODEX_HOME:-$HOME/.codex}/skills/.system/skill-creator/scripts/quick_validate.py"
fi
if [ ! -f "$validator" ]; then
	printf 'skill validator not found; install the Codex skill-creator system skill\n' >&2
	exit 1
fi

git ls-files --cached --others --exclude-standard '.agents/skills/*/SKILL.md' |
	while IFS= read -r skill_file; do
		[ -f "$skill_file" ] || continue
		uv run --quiet --with PyYAML python "$validator" "$(dirname "$skill_file")"
	done

git diff --check
printf '%s\n' 'all checks passed'
